  "session": 21,
  "title": "Hyperbolic Function Complexity",
  "rotation_theorem": {
    "statement": "Rotation Theorem (CEML-T12):\nAll six hyperbolic functions are EML-1 over \u2102:\n  sinh(x) = -i\u00b7sin(ix)  = -i\u00b7Im(ceml(i\u00b7(ix),1)) = -i\u00b7Im(ceml(-x,1))\n            equivalently: (ceml(x,1) - ceml(-x,1))/2\n  cosh(x) = cos(ix)     = Re(ceml(i\u00b7(ix),1)) = Re(ceml(-x,1))\n  tanh(x) = sinh(x)/cosh(x) \u2014 ratio of same depth-1 node\n  csch, sech, coth \u2014 reciprocals of the above",
    "key_identity": "Hyperbolic \u2194 Trig via rotation by i: f_hyp(x) = f_trig(ix) (up to signs)"
  },
  "inverse_hyperbolic": [
    {
      "fn": "arcsinh(x)",
      "depth": 2,
      "formula": "Log(x+sqrt(x^2+1))",
      "note": "Log is depth-1 arithmetic; sqrt needs depth-2 pure tree"
    },
    {
      "fn": "arccosh(x)",
      "depth": 2,
      "formula": "Log(x+sqrt(x^2-1))  [x\u22651]",
      "note": "Same structure as arcsinh"
    },
    {
      "fn": "arctanh(x)",
      "depth": 2,
      "formula": "(1/2)Log((1+x)/(1-x))  [|x|<1]",
      "note": "Log of rational function"
    },
    {
      "fn": "arccsch(x)",
      "depth": 2,
      "formula": "arcsinh(1/x)",
      "note": "Composition with reciprocal"
    },
    {
      "fn": "arcsech(x)",
      "depth": 2,
      "formula": "arccosh(1/x)",
      "note": "Same"
    },
    {
      "fn": "arccoth(x)",
      "depth": 2,
      "formula": "arctanh(1/x)",
      "note": "Same"
    }
  ],
