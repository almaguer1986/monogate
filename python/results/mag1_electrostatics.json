      "canonical_nodes": 7,
      "notes": "Structurally identical to capacitor energy (id=4); same folding applies."
    },
    {
      "id": 9,
      "name": "Electric Potential Energy (two charges)",
      "formula": "U = k*q1*q2 / r",
      "variants": [
        {
          "label": "free charges",
          "ops": {
            "mul(q1,q2)": 2,
            "mul(k,product)": 2,
            "div(result,r)": 1
          },
          "total_nodes": 5
        },
        {
          "label": "kq1q2 as constant",
          "ops": {
            "div(const,r)": 1
          },
          "total_nodes": 1
        }
      ],
      "canonical_nodes": 5,
      "notes": "Collapses to 1n for fixed charge pairs — same floor as Gauss flux."
    },
    {
      "id": 10,
      "name": "Self-Capacitance of a Sphere",
      "formula": "C = 4*pi*epsilon0 * R",
      "variants": [
        {
          "label": "4*pi*eps0 as constant",
          "ops": {
            "mul(4pi_eps0, R)": 2
          },
          "total_nodes": 2
        }
