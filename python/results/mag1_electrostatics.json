{
  "session": "MAG-1",
  "title": "Electrostatics and Magnetostatics — SuperBEST Cost Analysis",
  "superBEST_version": "v3",
  "cost_model": {
    "exp": 1,
    "ln": 1,
    "neg": 2,
    "recip": 2,
    "mul": 2,
    "sub": 2,
    "div": 1,
    "pow": 3,
    "add_pos": 3,
    "sin_cos": 1,
    "parameters_constants": 0,
    "note": "sin/cos cost 1 as complex EML nodes"
  },
  "equations": [
    {
      "id": 1,
      "name": "Coulomb's Law",
      "formula": "F = k*q1*q2 / r^2",
      "variants": [
        {
          "label": "free charges",
          "ops": {
            "mul(q1,q2)": 2,
            "mul(k,product)": 2,
            "pow(r,2)": 3,
            "div": 1
          },
          "total_nodes": 8
        },
        {
          "label": "kq1 or kq1q2 precomputed (fixed charges)",
          "ops": {
            "pow(r,2)": 3,
            "div(const,pow)": 1
          },
          "total_nodes": 4
        }
      ],
      "canonical_nodes": 8,
      "notes": "With k as free constant, cost is same 8n. Fixed-charge regime collapses to 4n."
    },
    {
      "id": 2,
      "name": "Electric Field (point charge)",
      "formula": "E = k*q / r^2",
      "variants": [
        {
          "label": "free q",
          "ops": {
            "mul(k,q)": 2,
            "pow(r,2)": 3,
            "div": 1
          },
          "total_nodes": 6
        },
        {
          "label": "kq as constant",
          "ops": {
            "pow(r,2)": 3,
            "div(const,pow)": 1
          },
          "total_nodes": 4
        }
      ],
      "canonical_nodes": 6,
      "notes": "Collapses to 4n when kq is a precomputed constant."
    },
    {
      "id": 3,
      "name": "Electric Potential (point charge)",
      "formula": "V = k*q / r",
      "variants": [
        {
          "label": "free charges",
          "ops": {
            "mul(k,q)": 2,
            "div(kq,r)": 1
          },
          "total_nodes": 3
        },
        {
          "label": "kq as constant",
          "ops": {
            "div(const,r)": 1
          },
          "total_nodes": 1
        }
      ],
      "canonical_nodes": 3,
      "notes": "Cheapest non-trivial electrostatic quantity. Collapses to 1n for fixed charges."
    },
    {
      "id": 4,
      "name": "Capacitor Energy",
      "formula": "U = (1/2) * C * V^2",
      "variants": [
        {
          "label": "general",
          "ops": {
            "pow(V,2)": 3,
            "mul(C,V2)": 2,
            "mul(0.5,product)": 2
          },
          "total_nodes": 7
        },
        {
          "label": "half-C as constant (0.5*C folded)",
          "ops": {
            "pow(V,2)": 3,
            "mul(0.5C,V2)": 2
          },
          "total_nodes": 5
        }
      ],
      "canonical_nodes": 7,
      "notes": "0.5 is a free constant; folding into C saves one mul node."
    },
    {
      "id": 5,
      "name": "Biot-Savart Law (magnitude)",
      "formula": "dB = (mu0*I / 4*pi*r^2) * dl * sin(theta)",
      "variants": [
        {
          "label": "mu0*I/4pi as constant",
          "ops": {
            "pow(r,2)": 3,
            "recip(r2)": 2,
            "mul(dl,recip)": 2,
            "sin(theta)": 1,
            "mul(sin,product)": 2,
            "mul(const,result)": 2
          },
          "total_nodes": 12
        },
        {
          "label": "further folding (mu0*I*dl/4pi as constant)",
          "ops": {
            "pow(r,2)": 3,
            "recip(r2)": 2,
            "sin(theta)": 1,
            "mul(sin,recip)": 2,
            "mul(const,result)": 2
          },
          "total_nodes": 10
        }
      ],
      "canonical_nodes": 12,
      "notes": "sin(theta) costs 1 as complex EML node. Minimum 10n with maximal constant folding."
    },
    {
      "id": 6,
      "name": "Magnetic Dipole Moment Field (radial component)",
      "formula": "B_r = (mu0 / 4*pi) * (2*m / r^3) * cos(theta)",
      "variants": [
        {
          "label": "mu0*2m/4pi as constant",
          "ops": {
            "pow(r,3)": 3,
            "recip(r3)": 2,
            "mul(2m,recip)": 2,
            "cos(theta)": 1,
            "mul(cos,product)": 2,
            "mul(const,result)": 2
          },
          "total_nodes": 12
        }
      ],
      "canonical_nodes": 12,
      "notes": "Symmetric cost to Biot-Savart; cos(theta) costs 1 as complex EML node."
    },
    {
      "id": 7,
      "name": "Gauss's Law (electric flux)",
      "formula": "Phi = Q_enc / epsilon0",
      "variants": [
        {
          "label": "general",
          "ops": {
            "div(Q,eps0)": 1
          },
          "total_nodes": 1
        }
      ],
      "canonical_nodes": 1,
      "notes": "Cheapest equation in the session. Epsilon_0 is a free constant."
    },
    {
      "id": 8,
      "name": "Inductance Energy",
      "formula": "U = (1/2) * L * I^2",
      "variants": [
        {
          "label": "general",
          "ops": {
            "pow(I,2)": 3,
            "mul(L,I2)": 2,
            "mul(0.5,product)": 2
