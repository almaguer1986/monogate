    {
      "id": "HH-1",
      "name": "Hodgkin-Huxley total current",
      "equation": "I = gNa·m³·h·(V−ENa) + gK·n⁴·(V−EK) + gL·(V−EL)",
      "domain": "general",
      "total_nodes": 30,
      "breakdown": {
        "Na_channel_term": {
          "expression": "gNa·m³·h·(V−ENa)",
          "nodes": 11,
          "steps": [
            {"op": "pow(m, 3)", "cost": 3},
            {"op": "mul(gNa, m³)", "cost": 2},
            {"op": "mul(result, h)", "cost": 2},
            {"op": "sub(V, ENa)", "cost": 2},
            {"op": "mul(result, sub)", "cost": 2}
          ]
        },
        "K_channel_term": {
          "expression": "gK·n⁴·(V−EK)",
          "nodes": 9,
          "steps": [
            {"op": "pow(n, 4)", "cost": 3},
            {"op": "mul(gK, n⁴)", "cost": 2},
            {"op": "sub(V, EK)", "cost": 2},
            {"op": "mul(result, sub)", "cost": 2}
          ]
        },
        "leak_term": {
          "expression": "gL·(V−EL)",
          "nodes": 4,
          "steps": [
            {"op": "sub(V, EL)", "cost": 2},
            {"op": "mul(gL, sub)", "cost": 2}
          ]
        },
        "summation": {
          "expression": "Na_term + K_term + leak_term",
          "nodes": 6,
          "steps": [
            {"op": "add(Na_term, K_term)", "cost": 3},
            {"op": "add(result, leak_term)", "cost": 3}
          ],
          "note": "add uses positive-domain cost=3 here since conductance terms are non-negative"
        }
      },
      "notes": "Most important computation in neuroscience. Na: 11n, K: 9n, Leak: 4n, Summation: 6n."
    },
    {
      "id": "HH-2",
      "name": "HH gating variable αm(V)",
      "equation": "αm(V) = 0.1·(V+40) / (1 − exp(−(V+40)/10))",
