{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://monogate.org/schemas/capcard/v3.json",
  "title": "CapCard v3 — Math + Neural vertical",
  "description": "Extends the v2 capability card with EML/SuperBEST structural metrics and neural-cost fields so agents can filter tools by verifiable complexity, not marketing.",
  "type": "object",
  "required": [
    "capcard_version", "id", "name", "type", "description", "version",
    "license", "homepage", "repository", "capabilities", "benchmarks",
    "proofs", "verification", "metadata"
  ],
  "properties": {
    "capcard_version": { "type": "string", "pattern": "^3\\.\\d+\\.\\d+$" },
    "id": { "type": "string" },
    "name": { "type": "string" },
    "type": {
      "type": "string",
      "enum": ["library", "service", "model", "dataset", "tool", "agent"]
    },
    "description": { "type": "string" },
    "version": { "type": "string" },
    "license": { "type": "string" },
    "homepage": { "type": "string", "format": "uri" },
    "repository": { "type": "string", "format": "uri" },
    "lean_repo": { "type": "string", "format": "uri" },

    "capabilities": {
      "type": "array", "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "category", "description", "status"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "category": {
            "type": "string",
            "enum": [
              "scientific_claim", "cost_theory", "taxonomy", "lower_bound",
              "upper_bound", "construction", "empirical_dataset", "conjecture",
              "tool_function", "model_capability"
            ]
          },
          "description": { "type": "string" },
          "status": {
            "type": "string",
            "enum": ["proven", "proven_partial", "proven_machine_verified",
                     "empirically_confirmed", "conjecture", "declared"]
          },

          "eml_metrics": {
            "type": "object",
            "description": "Structural metrics for elementary-function capabilities (v3 extension).",
            "properties": {
              "depth_max":        { "type": "integer", "minimum": 0 },
              "eml_k":            { "type": "integer", "minimum": 0,
                                     "description": "Minimum EML depth class of the capability's output." },
              "superbest_nodes":  { "type": "integer", "minimum": 0 },
              "superbest_nodes_general": { "type": "integer", "minimum": 0 },
              "naive_nodes":      { "type": "integer", "minimum": 0 },
              "savings_percent":  { "type": "number" },
              "elc_class": {
                "type": "string",
                "enum": ["inside", "boundary", "outside_piecewise", "undefined"]
              },
              "operator_family": {
                "type": "array",
                "items": { "type": "string",
                            "enum": ["EML", "EDL", "EMN", "EXL", "EAL", "DEML",
                                     "EPL", "LEAd", "ELAd", "ELSb", "LEdiv", "LEprod"] }
              },
              "pattern_bonus":    { "type": "array", "items": { "type": "string" } },
              "verified_by":      { "type": "string",
                                     "enum": ["lean4", "mathlib", "python_exact", "empirical", "unverified"] },
              "lean_file":        { "type": "string" },
              "lean_theorem":     { "type": "string" }
            }
          },

          "neural_metrics": {
            "type": "object",
            "description": "Per-capability neural training cost (v3 extension).",
            "properties": {
              "forward_nodes":       { "type": "integer", "minimum": 0 },
              "backward_nodes":      { "type": "integer", "minimum": 0 },
              "parameters":          { "type": "integer", "minimum": 0 },
              "optimizer":           { "type": "string" },
              "optimizer_nodes_per_param_per_step": { "type": "integer", "minimum": 0 },
              "loss_name":           { "type": "string" },
              "loss_nodes_per_sample": { "type": "integer", "minimum": 0 },
              "normalization":       { "type": "string",
                                        "enum": ["none", "BN", "LN", "RMS", "GN"] },
              "training_total_nodes": { "type": "number" },
              "training_superbest_savings": { "type": "number" }
            }
          },

          "agent_usage": {
            "type": "object",
            "description": "Declared agent-facing invocation signature (v3 extension).",
            "properties": {
              "input_schema":  { "type": "object" },
              "output_schema": { "type": "object" },
              "determinism":   { "type": "string", "enum": ["deterministic", "stochastic"] },
              "latency_ms_p50": { "type": "number" },
              "cost_per_call_usd": { "type": "number" }
            }
          },

          "constraints": { "type": "object" },
          "tags": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "benchmarks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "metric", "value"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "capability_ref": { "type": "string" },
          "metric": { "type": "string" },
          "value": {},
          "unit": { "type": "string" },
          "direction": { "type": "string",
                          "enum": ["higher_is_better", "lower_is_better"] },
          "reproducibility": {
            "type": "object",
            "properties": {
              "command": { "type": "string" },
              "deterministic": { "type": "boolean" },
              "dataset_sha256": { "type": "string" }
            }
          },
          "eml_cost_profile": {
            "type": "object",
            "properties": {
              "nodes_per_call": { "type": "integer" },
              "savings_vs_naive_pct": { "type": "number" }
            }
          },
          "notes": { "type": "string" }
        }
      }
    },

    "proofs": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "name", "statement", "status", "sorries"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "statement": { "type": "string" },
          "status": { "type": "string",
                       "enum": ["proven_machine_verified", "proven_partial"] },
          "proof_method": { "type": "string" },
          "lean_file": { "type": "string" },
          "lean_theorem": { "type": "string" },
          "sorries": { "type": "integer", "minimum": 0 },
          "sorries_description": { "type": "string" },
          "capability_refs": { "type": "array", "items": { "type": "string" } }
        }
      }
    },

    "verification": {
      "type": "object",
      "required": ["test_count", "last_verified"],
      "properties": {
        "test_count": { "type": "integer", "minimum": 0 },
        "test_pass_rate": { "type": "number", "minimum": 0, "maximum": 1 },
        "last_verified": { "type": "string", "format": "date-time" },
        "lean_clean_files": { "type": "integer", "minimum": 0 },
        "lean_partial_files": { "type": "integer", "minimum": 0 },
        "lean_sorries_total": { "type": "integer", "minimum": 0 },
        "trust_score": {
          "type": "object",
          "properties": {
            "value": { "type": "number", "minimum": 0, "maximum": 1 },
            "version": { "type": "string" },
            "notes": { "type": "string" }
          }
        }
      }
    },

    "agent_queries": {
      "type": "object",
      "description": "Example queries that an agent would use to filter tools (v3 extension).",
      "properties": {
        "supports": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Freeform capability tags — e.g. 'symbolic_regression', 'exp', 'elc_interior'."
        },
        "sla": {
          "type": "object",
          "properties": {
            "max_latency_ms":   { "type": "number" },
            "max_cost_usd":     { "type": "number" },
            "determinism":      { "type": "string" },
            "max_nodes":        { "type": "integer" },
            "min_savings_pct":  { "type": "number" }
          }
        }
      }
    },

    "integration": { "type": "object" },
    "metadata": {
      "type": "object",
      "required": ["created", "updated"],
      "properties": {
        "created": { "type": "string", "format": "date-time" },
        "updated": { "type": "string", "format": "date-time" },
        "schema_url": { "type": "string", "format": "uri" }
      }
    }
  }
}
