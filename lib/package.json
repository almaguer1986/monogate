{
  "name": "monogate",
  "version": "1.2.0",
  "description": "A single binary operator eml(x,y) = exp(x) − ln(y) that generates all elementary functions. Implementation of arXiv:2603.21852 (Odrzywołek, 2026). Includes Pfaffian cost analysis for symbolic expression trees.",
  "type": "module",
  "main": "./src/index.js",
  "exports": {
    ".": {
      "import": "./src/index.js"
    },
    "./cost": {
      "import": "./src/cost.js"
    }
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "mathematics",
    "eml",
    "elementary-functions",
    "algebra",
    "monogate",
    "exp-minus-log",
    "pfaffian",
    "symbolic-computation",
    "cost-analysis"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/almaguer1986/monogate.git"
  },
  "homepage": "https://github.com/almaguer1986/monogate",
  "bugs": {
    "url": "https://github.com/almaguer1986/monogate/issues"
  },
  "engines": {
    "node": ">=16"
  },
  "devDependencies": {
    "vitest": "^1.0.0"
  },
  "scripts": {
    "test": "vitest run"
  }
}
