---
interface Props {
  title: string;
  description?: string;
  date?: string;
  type?: "website" | "article";
}
const { title, description, date, type = "website" } = Astro.props;
const canonical = Astro.url.pathname.replace(/\/$/, "") || "/";
const pageUrl = `https://monogate.org${canonical}`;

// Root-level project JSON-LD (shown on every page)
const projectLd = {
  "@context": "https://schema.org",
  "@type": "ResearchProject",
  name: "Monogate",
  alternateName: "Monogate Research",
  description:
    "EML operator framework for elementary function optimization. " +
    "One binary operator eml(x, y) = exp(x) - ln(y) generates every elementary " +
    "function as a finite tree. SuperBEST routing proves 80.8% node savings on " +
    "the 10 positive-domain primitives; 11 Lean 4 files at 0 sorries verify the " +
    "core lower bounds.",
  url: "https://monogate.org",
  sameAs: [
    "https://github.com/almaguer1986/monogate",
    "https://github.com/almaguer1986/monogate-lean",
    "https://pypi.org/project/monogate/",
    "https://arxiv.org/abs/2603.21852",
    "https://monogate.dev",
  ],
  codeRepository: "https://github.com/almaguer1986/monogate",
  author: { "@type": "Organization", name: "Monogate Research" },
  license: "https://opensource.org/licenses/MIT",
};

// Per-page Article JSON-LD when `date` is set (blog posts etc.)
const articleLd = (type === "article" || date) ? {
  "@context": "https://schema.org",
  "@type": "Article",
  headline: title,
  description: description ?? undefined,
  datePublished: date ?? undefined,
  dateModified: date ?? undefined,
  author: { "@type": "Organization", name: "Monogate Research" },
  publisher: {
    "@type": "Organization", name: "Monogate Research",
    url: "https://monogate.org",
    logo: { "@type": "ImageObject", url: "https://monogate.org/logo.svg" },
  },
  mainEntityOfPage: { "@type": "WebPage", "@id": pageUrl },
  url: pageUrl,
  image: "https://monogate.org/og-image.jpg",
  isPartOf: { "@type": "Blog", name: "Monogate Research Blog", url: "https://monogate.org/blog" },
} : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    {description && <meta name="description" content={description} />}
    <title>{title}</title>
    <link rel="canonical" href={pageUrl} />
    <link rel="icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <link rel="alternate" type="application/rss+xml" title="Monogate Research Blog" href="/rss.xml" />
    <link rel="sitemap" type="application/xml" title="Sitemap" href="/sitemap.xml" />

    <!-- Open Graph / Facebook -->
    <meta property="og:title" content={title ?? "Monogate — One Operator for All Elementary Functions"} />
    <meta property="og:description" content={description ?? "16 operators. 14 nodes. 80.8% savings. Proved optimal."} />
    <meta property="og:image" content="https://monogate.org/og-image.jpg" />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content="Monogate" />
    {date && <meta property="article:published_time" content={date} />}

    <!-- Twitter Card -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title ?? "Monogate — One Operator for All Elementary Functions"} />
    <meta name="twitter:description" content={description ?? "16 operators. 14 nodes. 80.8% savings. Proved optimal."} />
    <meta name="twitter:image" content="https://monogate.org/og-image.jpg" />

    <!-- Structured data -->
    <script type="application/ld+json" set:html={JSON.stringify(projectLd)} />
    {articleLd && <script type="application/ld+json" set:html={JSON.stringify(articleLd)} />}
    <style>
      :root {
        --bg: #fafaf8;
        --surface: #f4f4f0;
        --border: #e2e2d8;
        --text: #1a1a1a;
        --muted: #6b7280;
        --accent: #4facfe;
        --cyan: #0e7490;         /* darkened from #2563eb — AA 5.0:1 on --bg */
        --pink: #be185d;         /* darkened from #be185d — AA 5.1:1 */
        --orange: #e8a020;       /* brand, used on the large wordmark only (3:1 for large text) */
        --green: #15803d;        /* NEW — "savings" highlights; AA 4.5:1 */
        --violet: #6d28d9;       /* NEW — AA 5.9:1 */
        --red: #b91c1c;          /* NEW — AA 6.0:1 */
        --mono: 'Space Mono', monospace;
        --serif: 'Georgia', serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      html, body {
        background: var(--bg);
        color: var(--text);
        font-family: var(--serif);
        font-size: 16px;
        line-height: 1.75;
        -webkit-font-smoothing: antialiased;
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      nav {
        border-bottom: 1px solid var(--border);
        padding: 14px 24px;
        display: flex;
        align-items: center;
        justify-content: space-between;
        font-family: var(--mono);
        font-size: 12px;
        max-width: 800px;
        margin: 0 auto;
        position: relative;
      }
      nav .brand { color: var(--orange); font-weight: 700; letter-spacing: 2px; text-transform: uppercase; text-decoration: none; }
      nav .brand:hover { text-decoration: none; }
      nav .links { display: flex; gap: 24px; color: var(--muted); }
      nav .links a { color: var(--muted); }
      nav .links a:hover { color: var(--text); text-decoration: none; }
      nav .links a.active { color: var(--text); }
      .hamburger {
        display: none;
        background: none;
        border: 1px solid var(--border);
        border-radius: 4px;
        color: var(--muted);
        font-size: 14px;
        padding: 5px 9px;
        cursor: pointer;
        font-family: var(--mono);
        line-height: 1;
        transition: border-color 0.15s, color 0.15s;
      }
      .hamburger:hover { border-color: var(--accent); color: var(--accent); }
      .mobile-menu {
        display: none;
        flex-direction: column;
        background: var(--surface);
        border-bottom: 1px solid var(--border);
        font-family: var(--mono);
        font-size: 11px;
        max-width: 800px;
        margin: 0 auto;
      }
      .mobile-menu.open { display: flex; }
      .mobile-menu a {
        padding: 13px 24px;
        border-bottom: 1px solid var(--border);
        color: var(--muted);
        letter-spacing: 0.08em;
        text-transform: uppercase;
        text-decoration: none;
        transition: color 0.15s, background 0.15s;
      }
      .mobile-menu a:last-child { border-bottom: none; }
      .mobile-menu a:hover { color: var(--text); background: rgba(255,255,255,0.02); }
      @media (max-width: 600px) {
        nav .links { display: none; }
        .hamburger { display: block; }
      }
      main {
        max-width: 680px;
        margin: 0 auto;
        padding: 48px 24px 80px;
      }
      h1 { font-size: 2rem; font-weight: 400; letter-spacing: -0.5px; color: var(--text); margin-bottom: 8px; line-height: 1.3; }
      h2 { font-size: 1.4rem; font-weight: 400; color: var(--text); margin: 36px 0 12px; }
      h3 { font-size: 1.1rem; font-weight: 600; color: var(--text); margin: 24px 0 8px; }
      p { margin-bottom: 20px; color: var(--text); }
      code {
        font-family: var(--mono);
        font-size: 0.85em;
        background: var(--surface);
        border: 1px solid var(--border);
        padding: 2px 6px;
        border-radius: 4px;
        color: var(--cyan);
      }
      pre {
        background: var(--surface);
        border: 1px solid var(--border);
        border-radius: 8px;
        padding: 20px;
        overflow-x: auto;
        margin: 24px 0;
      }
      pre code {
        background: none;
        border: none;
        padding: 0;
        font-size: 0.88em;
        color: var(--text);
      }
      .meta {
        font-family: var(--mono);
        font-size: 11px;
        color: var(--muted);
        margin-bottom: 32px;
        display: flex;
        gap: 16px;
      }
      .divider { width: 40px; height: 1px; background: var(--accent); margin: 40px 0; }
      blockquote {
        border-left: 2px solid var(--accent);
        padding-left: 16px;
        color: var(--muted);
        font-style: italic;
        margin: 24px 0;
      }
      .math-block {
        text-align: center;
        font-family: var(--mono);
        font-size: 1.2em;
        color: var(--accent);
        padding: 20px;
        background: rgba(79,172,254,0.06);
        border: 1px solid rgba(79,172,254,0.15);
        border-radius: 12px;
        margin: 24px 0;
      }
      footer {
        border-top: 1px solid var(--border);
        padding: 24px;
        text-align: center;
        font-family: var(--mono);
        font-size: 11px;
        color: var(--muted);
        max-width: 800px;
        margin: 0 auto;
      }
    </style>
  </head>
  <body>
    <nav id="site-nav">
      <a class="brand" href="/">MONOGATE</a>
      <div class="links">
        <a href="/one-operator">One Operator</a>
        <a href="/superbest">SuperBEST</a>
        <a href="/framework">Framework</a>
        <a href="/atlas">Atlas</a>
        <a href="/theorems">Theorems</a>
        <a href="/proofs">Proofs</a>
        <a href="/blog">Blog</a>
        <a href="/paper">Paper</a>
      </div>
      <button class="hamburger" id="nav-toggle" aria-label="Toggle menu" aria-expanded="false">☰</button>
    </nav>
    <div class="mobile-menu" id="mobile-menu" role="menu">
      <a href="/one-operator" role="menuitem">One Operator</a>
      <a href="/superbest" role="menuitem">SuperBEST</a>
      <a href="/framework" role="menuitem">Framework</a>
      <a href="/atlas" role="menuitem">Atlas</a>
      <a href="/theorems" role="menuitem">Theorems</a>
      <a href="/proofs" role="menuitem">Proofs</a>
      <a href="/blog" role="menuitem">Blog</a>
      <a href="/paper" role="menuitem">Paper</a>
    </div>
    <main>
      <slot />
    </main>
    <footer>
      Monogate Research · <a href="https://arxiv.org/abs/2603.21852">arXiv:2603.21852</a> · 11 Lean proofs · 265 equations · <a href="https://monogate.org">monogate.org</a> · <a href="https://monogate.dev">monogate.dev</a> · <a href="https://github.com/almaguer1986/monogate">GitHub</a> · <a href="https://pypi.org/project/monogate/">PyPI</a>
    </footer>
  </body>
  <script>
    const toggle = document.getElementById('nav-toggle')!;
    const menu   = document.getElementById('mobile-menu')!;
    toggle.addEventListener('click', () => {
      const open = menu.classList.toggle('open');
      toggle.textContent = open ? '✕' : '☰';
      toggle.setAttribute('aria-expanded', String(open));
    });
  </script>
</html>
