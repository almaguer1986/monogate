---
import Base from '../layouts/Base.astro';
import superbest from '../data/superbest.json';

const ops = superbest.table;
const totals = superbest.totals;
---

<Base
  title="SuperBEST — Optimal EML Routing Table"
  description="Minimum node counts for every arithmetic primitive in the EML/F16 operator family. Positive-domain: 15n (79.5% savings). General-domain: 22n (69.9% savings)."
>
  <div class="meta">
    <span>SuperBEST v{superbest.version}</span>
    <span>{superbest.date}</span>
    <span>arXiv:2603.21852</span>
  </div>

  <h1>SuperBEST Routing Table</h1>
  <p style="color: var(--muted); font-style: italic; margin-bottom: 32px;">
    Minimum F16-node constructions for every elementary arithmetic primitive.
    Proved optimal via derivative obstruction lower bounds and explicit constructions.
  </p>

  <div class="divider"></div>

  <div class="domain-toggle" id="domain-toggle">
    <button class="toggle-btn active" id="btn-pos" onclick="setDomain('positive')">
      Positive domain (x &gt; 0)
    </button>
    <button class="toggle-btn" id="btn-gen" onclick="setDomain('general')">
      General domain (all ℝ)
    </button>
  </div>

  <div class="headline" id="headline-pos">
    <span class="headline-num">{totals.positive_headline}</span>
    <span class="headline-label">vs naive {totals.savings_positive.naive_total}n baseline</span>
  </div>
  <div class="headline" id="headline-gen" style="display:none">
    <span class="headline-num">{totals.general_headline}</span>
    <span class="headline-label">vs naive {totals.savings_general.naive_total}n baseline</span>
  </div>

  <div class="table-wrap">
    <table id="sb-table">
      <thead>
        <tr>
          <th>Operation</th>
          <th id="col-cost">Nodes (x&gt;0)</th>
          <th>Naive</th>
          <th id="col-construction">Construction (positive)</th>
          <th>Domain</th>
        </tr>
      </thead>
      <tbody>
        {ops.map(row => (
          <tr>
            <td class="op-name"><code>{row.op}</code></td>
            <td class="cost" id={`cost-${row.op.split('(')[0].trim()}`}>
              <span class="cost-pos">{row.cost_positive}</span>
              <span class="cost-gen" style="display:none">{typeof row.cost_general === 'number' ? row.cost_general : '—'}</span>
            </td>
            <td class="naive">{row.v4_cost ?? '—'}</td>
            <td class="construction">
              <span class="constr-pos"><code>{row.construction_positive}</code></span>
              <span class="constr-gen" style="display:none"><code>{row.construction_general}</code></span>
            </td>
            <td class="domain">
              <span class="dom-pos" style="font-size:11px;color:var(--muted)">{row.domain_positive}</span>
              <span class="dom-gen" style="display:none;font-size:11px;color:var(--muted)">{row.domain_general}</span>
            </td>
          </tr>
        ))}
      </tbody>
    </table>
  </div>

  <div class="notes-block">
    <h2>Key results</h2>
    <ul>
      <li><strong>add(x,y) = 2n for all reals</strong> — ADD-T1: <code>LEdiv(x, DEML(y,1)) = x+y</code></li>
      <li><strong>pow(x,n) = 1n for x&gt;0</strong> — EPL/ELMl: <code>exp(n·ln(x)) = xⁿ</code> is a direct F16 primitive</li>
      <li><strong>sqrt(x) = 1n for x&gt;0</strong> — EPL(0.5, x): same mechanism as pow, single F16 node. Verified.</li>
      <li><strong>mul general = 6n</strong> — via <code>neg(mul(neg(x), y))</code></li>
      <li>All 10 operations: positive domain ≤ 2 nodes each (7 ops at 1n, 3 at 2n)</li>
    </ul>
    <p style="margin-top:20px">
      Full proof: <a href="/paper">papers and Lean proofs</a> ·
      Interactive: <a href="https://monogate.dev/explorer" target="_blank" rel="noopener">explorer ↗</a>
    </p>
  </div>

  <style>
    .domain-toggle {
      display: flex;
      gap: 8px;
      margin-bottom: 16px;
    }
    .toggle-btn {
      font-family: var(--mono);
      font-size: 11px;
      padding: 6px 14px;
      border: 1px solid var(--border);
      border-radius: 4px;
      background: var(--surface);
      color: var(--muted);
      cursor: pointer;
      transition: all 0.15s;
    }
    .toggle-btn.active {
      border-color: var(--accent);
      color: var(--accent);
      background: rgba(79,172,254,0.06);
    }
    .headline {
      margin-bottom: 28px;
      font-family: var(--mono);
    }
    .headline-num {
      font-size: 1.4rem;
      font-weight: 700;
      color: var(--accent);
      margin-right: 12px;
    }
    .headline-label {
      font-size: 0.85rem;
      color: var(--muted);
    }
    .table-wrap {
      overflow-x: auto;
      margin: 0 -24px;
      padding: 0 24px;
    }
    table {
      width: 100%;
      border-collapse: collapse;
      font-size: 13px;
      font-family: var(--mono);
    }
    th {
      text-align: left;
      padding: 8px 12px;
      border-bottom: 1px solid var(--border);
      color: var(--muted);
      font-weight: 400;
      font-size: 11px;
      text-transform: uppercase;
      letter-spacing: 0.05em;
    }
    td {
      padding: 10px 12px;
      border-bottom: 1px solid var(--border);
      vertical-align: top;
    }
    .op-name code { color: var(--text); font-size: 13px; }
    .cost { font-weight: 700; color: var(--accent); font-size: 15px; }
    .naive { color: var(--muted); }
    .construction code { font-size: 11px; color: var(--cyan); }
    .notes-block {
      margin-top: 48px;
      padding: 24px;
      background: var(--surface);
      border: 1px solid var(--border);
      border-radius: 8px;
    }
    .notes-block ul {
      padding-left: 20px;
      margin: 12px 0;
    }
    .notes-block li { margin-bottom: 8px; }
  </style>

  <script>
    function setDomain(d) {
      const isPos = d === 'positive';
      document.getElementById('btn-pos').classList.toggle('active', isPos);
      document.getElementById('btn-gen').classList.toggle('active', !isPos);
      document.getElementById('headline-pos').style.display = isPos ? '' : 'none';
      document.getElementById('headline-gen').style.display = isPos ? 'none' : '';
      document.getElementById('col-cost').textContent = isPos ? 'Nodes (x>0)' : 'Nodes (all ℝ)';
      document.getElementById('col-construction').textContent = isPos ? 'Construction (positive)' : 'Construction (general)';
      document.querySelectorAll('.cost-pos, .constr-pos, .dom-pos').forEach(el => {
        (el as HTMLElement).style.display = isPos ? '' : 'none';
      });
      document.querySelectorAll('.cost-gen, .constr-gen, .dom-gen').forEach(el => {
        (el as HTMLElement).style.display = isPos ? 'none' : '';
      });
    }
    (window as any).setDomain = setDomain;
  </script>
</Base>
