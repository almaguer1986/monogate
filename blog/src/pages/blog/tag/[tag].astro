---
import Base from '../../../layouts/Base.astro';
import PostCardServer from '../../../components/PostCardServer.astro';
import { getAllPosts, getAllTags, tagMeta } from '../../../lib/posts';
import type { GetStaticPaths } from 'astro';

export const getStaticPaths: GetStaticPaths = () => {
  return getAllTags().map(tag => ({ params: { tag } }));
};

const { tag } = Astro.params;
if (!tag || !(tag in tagMeta)) throw new Error(`Unknown tag: ${tag}`);

const meta = tagMeta[tag];
const posts = getAllPosts().filter(p => p.tag === tag);
---

<Base
  title={`${meta.label} posts — Monogate Blog`}
  description={`All ${posts.length} posts tagged ${meta.label} on the Monogate Research blog.`}
>
  <h1 style="display:flex;align-items:center;gap:12px;flex-wrap:wrap;">
    <span style={`font-family:var(--mono);font-size:11px;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:${meta.color};background:${meta.color}15;border:1px solid ${meta.color}30;border-radius:3px;padding:6px 12px;`}>
      {meta.label}
    </span>
    <span style="font-size:1.2rem;color:var(--muted);font-weight:400;">
      {posts.length} {posts.length === 1 ? 'post' : 'posts'}
    </span>
  </h1>

  <p style="color:var(--muted);margin-bottom:28px;">
    <a href="/blog">← all posts</a>
    · <a href="/">monogate.org</a>
  </p>

  <div class="card-grid">
    {posts.map(p => <PostCardServer post={p} />)}
  </div>
</Base>

<style>
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  @media (min-width: 720px) {
    .card-grid { grid-template-columns: repeat(2, 1fr); }
  }
  /* Mirror of the card styling on /blog. Keeps both surfaces
     in lockstep — change one, change the other. */
  .post-card {
    border: 1px solid #2a2a35;
    border-radius: 8px;
    padding: 18px 20px;
    background: #15151c;
    height: 100%;
    display: flex;
    flex-direction: column;
  }
  .post-card .title {
    font-size: 16px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 10px;
    letter-spacing: -0.005em;
  }
  .post-card .title a {
    color: #c8a832;
    text-decoration: none;
  }
  .post-card .title a:hover,
  .post-card .title a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: #c8a832;
  }
  .post-card .desc {
    font-size: 13px;
    color: #b0b0b0;
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }
  .post-card .meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    padding-top: 10px;
    border-top: 1px solid #232330;
    font-family: var(--mono);
    font-size: 11px;
    color: #666;
  }
  .post-card .meta-sep { color: #444; }
  .post-card .meta-tag {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }
</style>
