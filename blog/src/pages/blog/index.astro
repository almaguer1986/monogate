---
import Base from '../../layouts/Base.astro';
import PostCardServer from '../../components/PostCardServer.astro';
import {
  getAllPosts, getFeaturedPosts, getRecentPosts, getRandomPosts,
  getAllTags, tagMeta,
} from '../../lib/posts';

const all       = getAllPosts();
const featured  = getFeaturedPosts();
const recent    = getRecentPosts(6);
const random    = getRandomPosts(6, 6);
const tagList   = getAllTags();
const counts    = Object.fromEntries(tagList.map(t => [t, all.filter(p => p.tag === t).length]));

// Search index for the client — only the fields the filter touches,
// to keep the JSON payload small.
const searchIndex = all.map(p => ({
  href: p.href,
  title: p.title,
  desc: p.desc,
  tag: p.tag,
  date: p.date,
}));
---

<Base
  title="Blog — monogate.org"
  description="Research blog on the EML operator: theorems, proofs, near-misses, and open problems."
>
  <h1>Research Blog</h1>
  <p style="color: var(--muted); margin-bottom: 20px;">
    {all.length} posts · <a href="/">← monogate.org</a> · <a href="/rss.xml">RSS</a>
  </p>

  <!-- ─── Search ─────────────────────────────────────────────────── -->
  <input
    id="blog-search"
    type="search"
    placeholder="Search posts…"
    aria-label="Search posts"
    autocomplete="off"
    style="width: 100%; box-sizing: border-box; background: var(--surface); border: 1px solid var(--border); border-radius: 8px; padding: 10px 14px; color: var(--text); font-family: var(--mono); font-size: 13px; margin-bottom: 16px;"
  />

  <!-- ─── Tag filter pills ───────────────────────────────────────── -->
  <div id="tag-filters" style="display: flex; gap: 6px; flex-wrap: wrap; margin-bottom: 28px;">
    <button
      data-tag="all"
      class="tag-btn active"
      style="font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: var(--text); background: #1a1a1a15; border: 1px solid #1a1a1a30; border-radius: 3px; padding: 4px 10px; cursor: pointer;"
    >all <span style="opacity:0.5">{all.length}</span></button>
    {tagList.map(tag => (
      <a
        href={`/blog/tag/${tag}`}
        data-tag={tag}
        class="tag-btn"
        style={`font-size: 9px; font-weight: 700; letter-spacing: 0.1em; text-transform: uppercase; color: ${tagMeta[tag].color}; background: ${tagMeta[tag].color}15; border: 1px solid ${tagMeta[tag].color}30; border-radius: 3px; padding: 4px 10px; cursor: pointer; text-decoration: none;`}
      >{tagMeta[tag].label} <span style="opacity:0.5">{counts[tag]}</span></a>
    ))}
  </div>

  <!-- ─── Search-result zone (hidden until typing) ───────────────── -->
  <section id="search-results" hidden>
    <h2 class="row-heading">Search results <span class="row-count" id="search-count"></span></h2>
    <div id="search-list" class="card-grid"></div>
  </section>

  <!-- ─── Three default rows ─────────────────────────────────────── -->
  <div id="default-view">
    {featured.length > 0 && (
      <section class="row">
        <h2 class="row-heading">Featured</h2>
        <div class="card-grid">
          {featured.map(p => <PostCardServer post={p} />)}
        </div>
      </section>
    )}

    <section class="row">
      <h2 class="row-heading">New</h2>
      <div class="card-grid">
        {recent.map(p => <PostCardServer post={p} />)}
      </div>
    </section>

    {random.length > 0 && (
      <section class="row">
        <h2 class="row-heading">From the archive <span class="row-sub">(picked at random)</span></h2>
        <div class="card-grid">
          {random.map(p => <PostCardServer post={p} />)}
        </div>
      </section>
    )}
  </div>

  <!-- Search index payload, embedded as JSON for the client filter. -->
  <script id="search-index" type="application/json" set:html={JSON.stringify(searchIndex)} />
  <script id="tag-meta" type="application/json" set:html={JSON.stringify(
    Object.fromEntries(Object.entries(tagMeta).map(([k, v]) => [k, { color: v.color, label: v.label }]))
  )} />
</Base>

{/* server-rendered card fragment so the three default rows share markup */}
<Fragment slot="afterMain">{/* unused; placeholder for future */}</Fragment>

<style>
  .row { margin-bottom: 36px; }
  .row-heading {
    font-family: var(--mono);
    font-size: 11px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: var(--muted);
    margin: 0 0 12px;
    padding-bottom: 6px;
    border-bottom: 1px solid var(--border);
  }
  .row-sub {
    font-weight: 400;
    text-transform: none;
    letter-spacing: 0;
    opacity: 0.7;
    margin-left: 6px;
  }
  .row-count {
    font-weight: 400;
    opacity: 0.6;
    margin-left: 8px;
  }
  .card-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 12px;
  }
  /* On wider screens, render 3 across — but only when there's enough room. */
  @media (min-width: 720px) {
    .card-grid { grid-template-columns: repeat(3, 1fr); }
  }
  /* Card: a plain <article>, NOT a link. Only the title is
     clickable. Subtle border + slightly-lighter surface separates
     each card from the page background. */
  .post-card {
    border: 1px solid #2a2a35;
    border-radius: 8px;
    padding: 18px 20px;
    background: #15151c;
    height: 100%;
    display: flex;
    flex-direction: column;
  }

  /* Title: gold, bold, the only clickable element on the card.
     The <a> inherits color so we only need to style underline on
     hover. Reset margins from the default <h3>. */
  .post-card .title {
    font-size: 16px;
    font-weight: 700;
    line-height: 1.3;
    margin: 0 0 10px;
    letter-spacing: -0.005em;
  }
  .post-card .title a {
    color: #c8a832;
    text-decoration: none;
  }
  .post-card .title a:hover,
  .post-card .title a:focus-visible {
    text-decoration: underline;
    text-underline-offset: 3px;
    text-decoration-color: #c8a832;
  }

  /* Description: regular text. Not a link. */
  .post-card .desc {
    font-size: 13px;
    color: #b0b0b0;
    line-height: 1.55;
    margin: 0;
    display: -webkit-box;
    -webkit-line-clamp: 4;
    line-clamp: 4;
    -webkit-box-orient: vertical;
    overflow: hidden;
    flex: 1;
  }

  /* Meta row: date · category tag, both dim gray. */
  .post-card .meta {
    display: flex;
    align-items: center;
    gap: 6px;
    margin-top: 14px;
    padding-top: 10px;
    border-top: 1px solid #232330;
    font-family: var(--mono);
    font-size: 11px;
    color: #666;
  }
  .post-card .meta-sep { color: #444; }
  .post-card .meta-tag {
    text-transform: uppercase;
    letter-spacing: 0.08em;
    font-weight: 600;
  }

  .tag-btn { transition: opacity 0.15s; display: inline-block; }
  .tag-btn:hover { opacity: 0.85; text-decoration: none; }
  .tag-btn.active { box-shadow: 0 0 0 1px currentColor; }
  #blog-search:focus { outline: none; border-color: var(--accent); }
</style>

<script>
  type IndexPost = {
    href: string; title: string; desc: string; tag: string; date: string;
  };
  type TagMetaEntry = { color: string; label: string };

  const idx: IndexPost[] = JSON.parse(
    document.getElementById('search-index')!.textContent!
  );
  const tagMeta: Record<string, TagMetaEntry> = JSON.parse(
    document.getElementById('tag-meta')!.textContent!
  );

  const search = document.getElementById('blog-search') as HTMLInputElement;
  const resultsZone = document.getElementById('search-results') as HTMLElement;
  const resultsList = document.getElementById('search-list') as HTMLElement;
  const resultsCount = document.getElementById('search-count') as HTMLElement;
  const defaultView = document.getElementById('default-view') as HTMLElement;

  function renderCard(p: IndexPost): string {
    const t = tagMeta[p.tag] ?? { color: 'var(--muted)', label: p.tag };
    const safeTitle = p.title.replace(/</g, '&lt;');
    const safeDesc  = p.desc.replace(/</g, '&lt;');
    const safeLabel = t.label.replace(/</g, '&lt;');
    return `
      <article class="post-card" data-tag="${p.tag}">
        <h3 class="title"><a href="${p.href}">${safeTitle}</a></h3>
        <p class="desc">${safeDesc}</p>
        <div class="meta">
          <time datetime="${p.date}">${p.date}</time>
          <span class="meta-sep" aria-hidden="true">·</span>
          <span class="meta-tag">${safeLabel}</span>
        </div>
      </article>
    `;
  }

  function runSearch() {
    const q = search.value.trim().toLowerCase();
    if (!q) {
      resultsZone.hidden = true;
      defaultView.hidden = false;
      return;
    }
    const matches = idx.filter(p =>
      p.title.toLowerCase().includes(q) ||
      p.desc.toLowerCase().includes(q) ||
      p.tag.toLowerCase().includes(q)
    );
    resultsCount.textContent = `· ${matches.length} match${matches.length === 1 ? '' : 'es'}`;
    resultsList.innerHTML = matches.length
      ? matches.map(renderCard).join('')
      : `<p style="color:var(--muted);font-size:12px;">No posts match “${q.replace(/</g, '&lt;')}”.</p>`;
    resultsZone.hidden = false;
    defaultView.hidden = true;
  }

  search.addEventListener('input', runSearch);
  // Allow Esc to clear.
  search.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      search.value = '';
      runSearch();
      search.blur();
    }
  });
</script>
